# Copy to .env and adjust as needed. Not loaded automatically by the app —
# export these into your shell (or your process manager) before running the backend.

# Directory for portfolio.db. Defaults to the repo root if unset.
# FOLIO_DATA_DIR=

# Port the backend listens on (used by backend/run_server.py, the packaged-app entrypoint).
# FOLIO_PORT=8000

# IBKR TWS/Gateway connection, used for live options pricing. See docs/ibkr-tws-setup.md.
# Port reference: TWS live 7496, TWS paper 7497, IB Gateway live 4001, IB Gateway paper 4002.
FOLIO_IBKR_HOST=127.0.0.1
FOLIO_IBKR_PORT=7496
FOLIO_IBKR_CLIENT_ID=17
